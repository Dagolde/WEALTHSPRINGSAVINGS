# Environment Configuration
ENVIRONMENT=development

# Application
APP_NAME=Rotational Contribution Microservices
APP_VERSION=1.0.0
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rotational_contribution
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DB=1
REDIS_CELERY_BROKER_DB=2
REDIS_CELERY_BACKEND_DB=3

# Celery
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=Africa/Lagos
CELERY_ENABLE_UTC=True

# Payment Gateway - Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_BASE_URL=https://api.paystack.co

# Payment Gateway - Flutterwave (Alternative)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TESTxxxxxxxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# Notification Services
# Firebase Cloud Messaging
FCM_SERVER_KEY=xxxxxxxxxxxxxxxxxxxxx
FCM_SENDER_ID=xxxxxxxxxxxxxxxxxxxxx

# SMS Gateway - Termii
TERMII_API_KEY=xxxxxxxxxxxxxxxxxxxxx
TERMII_SENDER_ID=RotationalApp
TERMII_BASE_URL=https://api.ng.termii.com/api

# Email Service - SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@rotationalapp.com
SENDGRID_FROM_NAME=Rotational Contribution App

# Laravel Backend Integration
LARAVEL_API_URL=http://localhost:8000/api/v1
LARAVEL_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Scheduler Configuration
PAYOUT_PROCESSING_TIME=00:00
CONTRIBUTION_REMINDER_TIME=09:00
MISSED_CONTRIBUTION_CHECK_TIME=23:00
GROUP_COMPLETION_CHECK_TIME=01:00
