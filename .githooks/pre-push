#!/bin/bash

# Git pre-push hook for running tests
# This hook runs before pushing to ensure all tests pass

set -e

echo "🧪 Running pre-push checks..."
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

CHECKS_FAILED=0

# Function to print colored output
print_status() {
    if [ $1 -eq 0 ]; then
        echo -e "${GREEN}✓${NC} $2"
    else
        echo -e "${RED}✗${NC} $2"
        CHECKS_FAILED=1
    fi
}

# Check 1: Run Laravel tests
if [ -f "backend/phpunit.xml" ]; then
    echo "Running Laravel tests..."
    cd backend
    php artisan test --parallel > /dev/null 2>&1
    LARAVEL_TEST_STATUS=$?
    cd ..
    
    if [ $LARAVEL_TEST_STATUS -ne 0 ]; then
        echo -e "${YELLOW}Laravel tests failed. Run: cd backend && php artisan test${NC}"
    fi
    print_status $LARAVEL_TEST_STATUS "Laravel tests"
    echo ""
fi

# Check 2: Run Python tests
if [ -f "microservices/pytest.ini" ] || [ -d "microservices/tests" ]; then
    echo "Running Python tests..."
    cd microservices
    pytest > /dev/null 2>&1
    PYTHON_TEST_STATUS=$?
    cd ..
    
    if [ $PYTHON_TEST_STATUS -ne 0 ]; then
        echo -e "${YELLOW}Python tests failed. Run: cd microservices && pytest${NC}"
    fi
    print_status $PYTHON_TEST_STATUS "Python tests"
    echo ""
fi

# Check 3: Ensure .env files are not being pushed
ENV_FILES=$(git diff --cached --name-only | grep -E '\.env$|\.env\.local$' || true)
if [ -n "$ENV_FILES" ]; then
    echo -e "${RED}✗ Attempting to push .env files:${NC}"
    echo "$ENV_FILES"
    echo -e "${YELLOW}Please remove .env files from commit${NC}"
    exit 1
fi

# Final result
echo ""
if [ $CHECKS_FAILED -eq 1 ]; then
    echo -e "${RED}❌ Pre-push checks failed. Please fix the issues above.${NC}"
    exit 1
else
    echo -e "${GREEN}✅ All pre-push checks passed!${NC}"
    exit 0
fi
