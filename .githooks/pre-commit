#!/bin/bash

# Git pre-commit hook for code quality checks
# This hook runs before each commit to ensure code quality standards

set -e

echo "🔍 Running pre-commit checks..."
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any checks fail
CHECKS_FAILED=0

# Function to print colored output
print_status() {
    if [ $1 -eq 0 ]; then
        echo -e "${GREEN}✓${NC} $2"
    else
        echo -e "${RED}✗${NC} $2"
        CHECKS_FAILED=1
    fi
}

# Get list of staged PHP files
STAGED_PHP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$' || true)

# Get list of staged Python files
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

# Check 1: PHP Syntax Check
if [ -n "$STAGED_PHP_FILES" ]; then
    echo "Checking PHP syntax..."
    PHP_SYNTAX_ERRORS=0
    for FILE in $STAGED_PHP_FILES; do
        php -l "$FILE" > /dev/null 2>&1
        if [ $? -ne 0 ]; then
            echo -e "${RED}Syntax error in: $FILE${NC}"
            PHP_SYNTAX_ERRORS=1
        fi
    done
    print_status $PHP_SYNTAX_ERRORS "PHP syntax check"
    echo ""
fi

# Check 2: PHP CS Fixer (Laravel backend)
if [ -n "$STAGED_PHP_FILES" ] && [ -f "backend/.php-cs-fixer.php" ]; then
    echo "Running PHP CS Fixer..."
    cd backend
    ./vendor/bin/php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.php > /dev/null 2>&1
    PHP_CS_STATUS=$?
    cd ..
    
    if [ $PHP_CS_STATUS -ne 0 ]; then
        echo -e "${YELLOW}Code style issues found. Run: cd backend && ./vendor/bin/php-cs-fixer fix${NC}"
    fi
    print_status $PHP_CS_STATUS "PHP CS Fixer"
    echo ""
fi

# Check 3: Psalm Static Analysis (Laravel backend)
if [ -n "$STAGED_PHP_FILES" ] && [ -f "backend/psalm.xml" ]; then
    echo "Running Psalm static analysis..."
    cd backend
    ./vendor/bin/psalm --no-cache --show-info=false > /dev/null 2>&1
    PSALM_STATUS=$?
    cd ..
    
    if [ $PSALM_STATUS -ne 0 ]; then
        echo -e "${YELLOW}Static analysis issues found. Run: cd backend && ./vendor/bin/psalm${NC}"
    fi
    print_status $PSALM_STATUS "Psalm static analysis"
    echo ""
fi

# Check 4: Python Syntax Check
if [ -n "$STAGED_PY_FILES" ]; then
    echo "Checking Python syntax..."
    PYTHON_SYNTAX_ERRORS=0
    for FILE in $STAGED_PY_FILES; do
        python -m py_compile "$FILE" > /dev/null 2>&1
        if [ $? -ne 0 ]; then
            echo -e "${RED}Syntax error in: $FILE${NC}"
            PYTHON_SYNTAX_ERRORS=1
        fi
    done
    print_status $PYTHON_SYNTAX_ERRORS "Python syntax check"
    echo ""
fi

# Check 5: Black formatter (Python)
if [ -n "$STAGED_PY_FILES" ] && command -v black &> /dev/null; then
    echo "Running Black formatter check..."
    cd microservices
    black --check . > /dev/null 2>&1
    BLACK_STATUS=$?
    cd ..
    
    if [ $BLACK_STATUS -ne 0 ]; then
        echo -e "${YELLOW}Code formatting issues found. Run: cd microservices && black .${NC}"
    fi
    print_status $BLACK_STATUS "Black formatter"
    echo ""
fi

# Check 6: Flake8 linter (Python)
if [ -n "$STAGED_PY_FILES" ] && command -v flake8 &> /dev/null; then
    echo "Running Flake8 linter..."
    cd microservices
    flake8 app/ > /dev/null 2>&1
    FLAKE8_STATUS=$?
    cd ..
    
    if [ $FLAKE8_STATUS -ne 0 ]; then
        echo -e "${YELLOW}Linting issues found. Run: cd microservices && flake8 app/${NC}"
    fi
    print_status $FLAKE8_STATUS "Flake8 linter"
    echo ""
fi

# Check 7: Prevent commits to main/master branch
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
    echo -e "${RED}✗ Direct commits to $BRANCH branch are not allowed${NC}"
    echo -e "${YELLOW}Please create a feature branch: git checkout -b feature/your-feature${NC}"
    exit 1
fi

# Check 8: Ensure no debug statements
if [ -n "$STAGED_PHP_FILES" ]; then
    DEBUG_FOUND=0
    for FILE in $STAGED_PHP_FILES; do
        if grep -qE "(dd\(|dump\(|var_dump\(|print_r\()" "$FILE"; then
            echo -e "${RED}Debug statement found in: $FILE${NC}"
            DEBUG_FOUND=1
        fi
    done
    if [ $DEBUG_FOUND -eq 1 ]; then
        echo -e "${YELLOW}Please remove debug statements before committing${NC}"
        CHECKS_FAILED=1
    fi
fi

# Final result
echo ""
if [ $CHECKS_FAILED -eq 1 ]; then
    echo -e "${RED}❌ Pre-commit checks failed. Please fix the issues above.${NC}"
    exit 1
else
    echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
    exit 0
fi
